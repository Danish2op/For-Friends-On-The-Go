# EAS Build Archive Ignore File
# This OVERRIDES .gitignore for EAS build archives.
# Key difference: .env.local and google-services.json are NOT ignored here,
# so they get uploaded to the EAS cloud build server.

# dependencies
node_modules/
functions/lib/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*
.tamagui/

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local guide
EAS_BUILD_GUIDE.md

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# NOTE: .env.local and google-services.json are intentionally NOT listed here.
# They must be included in the EAS build archive so that:
#   - app.config.ts can load EXPO_PUBLIC_* vars via dotenv
#   - Metro inlines them into the JS bundle at build time
#   - google-services.json configures Firebase native SDKs
