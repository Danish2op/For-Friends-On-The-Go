{
    "build": {
        "preview": {
            "channel": "preview",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EXPO_PUBLIC_OLA_MAPS_API_KEY": "replace_with_ola_maps_key",
                "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "replace_with_google_maps_key",
                "EXPO_PUBLIC_FIREBASE_API_KEY": "replace_with_firebase_web_api_key",
                "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN": "replace_with_firebase_auth_domain",
